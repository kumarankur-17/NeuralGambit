{
    "version": "2.0.0",
    "tasks": [
        {
            // "type": "cppbuild",
            "label": "C/C++: g++.exe build active file",
            "type": "shell",
            "command": "c:/MinGW/bin/g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-std=c++20",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "c:/MinGW/bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true,
            },
            "detail": "Task generated by Debugger."
        }
    ]
}